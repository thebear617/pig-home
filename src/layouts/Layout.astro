---
import '../styles/global.css';
import { TABS } from '../lib/tabs';

interface Props {
  activeTab: string;
  title?: string;
}

const { activeTab, title = '猪窝' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body data-page={activeTab}>
    <div class="layout">
      <button class="sidebar-toggle" id="sidebarToggle" aria-label="切换侧边栏">☰</button>
      <div class="sidebar-backdrop" id="sidebarBackdrop" hidden></div>

      <nav class="sidebar" id="sidebar" aria-label="主导航">
        <div class="sidebar-brand">
          <button class="sidebar-close" id="sidebarClose" aria-label="关闭侧边栏">✕</button>
          <p class="sidebar-eyebrow">Home Sweet Home</p>
          <h1 class="sidebar-title">猪窝</h1>
        </div>
        <div class="sidebar-nav" id="sidebarNav">
          {TABS.map(tab => (
            <a
              class={`sidebar-item${tab.id === activeTab ? ' active' : ''}`}
              href={`${base}${tab.id}/`}
              aria-current={tab.id === activeTab ? 'page' : undefined}
            >
              <span class="sidebar-icon">{tab.icon}</span>
              <span>{tab.title}</span>
            </a>
          ))}
        </div>
      </nav>

      <div class="main-area">
        <main id="app" class="app-shell">
          <slot />
        </main>
      </div>
    </div>

    <script>
      import '../scripts/layout';
    </script>
  </body>
</html>
