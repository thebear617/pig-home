---
import { getCollection } from 'astro:content';

const places = await getCollection('food-places');
const areaMap = new Map<string, Map<string, typeof places>>();
for (const place of places) {
  const area = place.data.area;
  const location = place.data.location;
  if (!areaMap.has(area)) areaMap.set(area, new Map());
  const locationMap = areaMap.get(area)!;
  if (!locationMap.has(location)) locationMap.set(location, []);
  locationMap.get(location)!.push(place);
}

const areaOrder = ['校内', '校外', ...Array.from(areaMap.keys()).filter(area => !['校内', '校外'].includes(area))]
  .filter(area => areaMap.has(area));
const defaultArea = areaOrder[0] || '';
const defaultLocation = Array.from(areaMap.get(defaultArea)?.keys() || []).sort()[0] || '';
const totalPlaces = places.length;
---

<div class="foodmap-page" data-tab="food-map">
  <header class="foodmap-header">
    <div>
      <p class="section-kicker">Food Notes</p>
      <h1>美食地图</h1>
      <p>按区域和地点整理去过、想去以及不再推荐的店。</p>
    </div>
    <div class="foodmap-total"><strong>{totalPlaces}</strong><span>家记录</span></div>
  </header>

  <div class="foodmap-layout">
    <aside class="foodmap-sidebar" aria-label="美食地点导航">
      <label class="foodmap-search">
        <span>搜索记录</span>
        <input type="search" data-fm-search placeholder="餐厅、菜品或评价" />
      </label>
      <div class="foodmap-area-list">
        {areaOrder.map(area => {
          const locationCount = areaMap.get(area)?.size || 0;
          const placeCount = Array.from(areaMap.get(area)?.values() || []).reduce((sum, items) => sum + items.length, 0);
          return (
            <button class={`foodmap-area-button${area === defaultArea ? ' active' : ''}`} data-fm-area={area} type="button">
              <span><b>{area}</b><small>{locationCount} 个地点 · {placeCount} 家</small></span>
              <span aria-hidden="true">›</span>
            </button>
          );
        })}
      </div>
    </aside>

    <main class="foodmap-results">
      {areaOrder.map(area => {
        const locationMap = areaMap.get(area);
        if (!locationMap) return null;
        const locations = Array.from(locationMap.keys()).sort();
        return (
          <div class="foodmap-area-content" data-fm-area-content={area} hidden={area !== defaultArea}>
            <div class="foodmap-results-heading">
              <div><p class="section-kicker">{area}</p><h2>去哪吃</h2></div>
              <span>{locations.length} 个地点</span>
            </div>
            <div class="foodmap-location-list">
              {locations.map(location => {
                const items = locationMap.get(location) || [];
                return (
                  <button class={`foodmap-location-button${area === defaultArea && location === defaultLocation ? ' active' : ''}`} data-fm-location={location} type="button">
                    <span>📍 {location}</span><small>{items.length}</small>
                  </button>
                );
              })}
            </div>
            {locations.map(location => {
              const items = locationMap.get(location) || [];
              const hidden = area !== defaultArea || location !== defaultLocation;
              return (
                <div class="foodmap-location-content" data-fm-location-content={location} hidden={hidden}>
                  <div class="foodmap-location-heading"><h3>{location}</h3><span>{items.length} 家记录</span></div>
                  <div class="foodmap-list">
                    {items.map(place => (
                      <article class="foodmap-list-item" data-fm-search-text={`${place.data.name} ${place.data.dishes.join(' ')} ${place.data.note || ''}`}>
                        <div class="foodmap-list-main">
                          <h4>{place.data.name}</h4>
                          {place.data.dishes.length > 0 && <p class="foodmap-dishes">{place.data.dishes.join(' · ')}</p>}
                          {place.data.note && <p class="foodmap-note">{place.data.note}</p>}
                        </div>
                        {place.data.date && <time datetime={place.data.date}>{place.data.date}</time>}
                      </article>
                    ))}
                  </div>
                  <p class="foodmap-no-results" hidden>没有匹配的记录</p>
                </div>
              );
            })}
          </div>
        );
      })}
    </main>
  </div>
</div>

<script>
  const root = document.querySelector<HTMLElement>('[data-tab="food-map"]');
  const search = root?.querySelector<HTMLInputElement>('[data-fm-search]');
  search?.addEventListener('input', () => {
    const query = search.value.trim().toLocaleLowerCase();
    root?.querySelectorAll<HTMLElement>('[data-fm-location-content]').forEach(location => {
      const items = location.querySelectorAll<HTMLElement>('[data-fm-search-text]');
      let visible = 0;
      items.forEach(item => {
        const match = !query || (item.dataset.fmSearchText || '').toLocaleLowerCase().includes(query);
        item.hidden = !match;
        if (match) visible += 1;
      });
      const empty = location.querySelector<HTMLElement>('.foodmap-no-results');
      if (empty) empty.hidden = visible > 0;
    });
  });
</script>
