---
import { expenseCategories } from '../../data/expense-categories';
import { pad, escapeHtml } from '../../lib/helpers';

const today = new Date();
const calYear = today.getFullYear();
const calMonth = today.getMonth() + 1;
---

<div data-tab="expense-records">
  <div class="expense-view" id="expenseView">
    <div class="cal-header">
      <span class="cal-title">{calYear}年{calMonth}月 · 支出</span>
      <div class="cal-nav">
        <button class="cal-nav-btn cal-prev">◀</button>
        <button class="cal-today-btn cal-today">本月</button>
        <button class="cal-nav-btn cal-next">▶</button>
      </div>
    </div>
    <div class="expense-content" id="expenseContent">
      <div class="empty-state"><p>加载中...</p></div>
    </div>
  </div>
</div>
