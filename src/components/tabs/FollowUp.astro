---
import { getCollection } from 'astro:content';

const memos = (await getCollection('memos')).sort((a, b) => a.data.order - b.data.order);
const procurement = (await getCollection('procurement')).sort((a, b) => a.data.order - b.data.order);
const base = import.meta.env.BASE_URL;
---

<div class="follow-up-index" data-tab="follow-up">
  <header class="follow-up-header">
    <p class="section-kicker">Home Reference</p>
    <h1>生活备忘录与物资采购</h1>
    <p>把家里的规则、设备说明和采购清单整理成可独立访问的条目。</p>
  </header>

  <section class="follow-up-directory" aria-labelledby="memo-title">
    <div class="follow-up-section-heading">
      <div>
        <p class="section-kicker">Reference</p>
        <h2 id="memo-title">生活备忘录</h2>
      </div>
      <span>{memos.length} 个条目</span>
    </div>
    <div class="follow-up-link-list">
      {memos.map(memo => (
        <a class="follow-up-link" href={`${base}follow-up/memos/${memo.slug}/`}>
          <span class="follow-up-link-icon">{memo.data.icon || '📋'}</span>
          <span class="follow-up-link-main">
            <strong>{memo.data.region}</strong>
            <small>{memo.data.category}</small>
          </span>
          <span class="follow-up-link-arrow">→</span>
        </a>
      ))}
    </div>
  </section>

  <section class="follow-up-directory" aria-labelledby="procurement-title">
    <div class="follow-up-section-heading">
      <div>
        <p class="section-kicker">Checklist</p>
        <h2 id="procurement-title">物资采购</h2>
      </div>
      <span>{procurement.length} 个区域</span>
    </div>
    <div class="follow-up-link-list">
      {procurement.map(item => (
        <a class="follow-up-link" href={`${base}follow-up/procurement/${item.slug}/`}>
          <span class="follow-up-link-icon">{item.data.icon || '🛒'}</span>
          <span class="follow-up-link-main">
            <strong>{item.data.region}</strong>
            <small>{item.data.category}{item.data.note ? ` · ${item.data.note}` : ''}</small>
          </span>
          <span class="follow-up-link-arrow">→</span>
        </a>
      ))}
    </div>
  </section>
</div>
