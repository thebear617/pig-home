---
import { locations } from '../../data/locations';
---

<div data-tab="home-map">
  <div class="floor-plan">
    <svg viewBox="0 0 800 500" class="fp-svg">
      <rect x="0" y="0" width="280" height="200" rx="6" class="fp-room fp-master"/>
      <text x="140" y="100" class="fp-room-label">主卧</text>
      <text x="140" y="122" class="fp-room-area">~12㎡</text>

      <rect x="0" y="200" width="140" height="120" rx="6" class="fp-room fp-bath"/>
      <text x="70" y="260" class="fp-room-label">卫生间</text>
      <text x="70" y="282" class="fp-room-area">~4㎡</text>

      <rect x="140" y="200" width="140" height="120" rx="6" class="fp-room fp-wash"/>
      <text x="210" y="260" class="fp-room-label">洗漱台</text>

      <rect x="380" y="320" width="420" height="180" rx="6" class="fp-room fp-kitchen"/>
      <text x="590" y="410" class="fp-room-label">厨房</text>
      <text x="590" y="432" class="fp-room-area">~12㎡</text>

      <rect x="280" y="320" width="100" height="180" rx="6" class="fp-room fp-entry"/>
      <text x="330" y="415" class="fp-room-label fp-vertical-label">入户通道</text>

      <rect x="0" y="320" width="280" height="180" rx="6" class="fp-room fp-second"/>
      <text x="140" y="410" class="fp-room-label">次卧</text>
      <text x="140" y="432" class="fp-room-area">~7㎡</text>

      <rect x="280" y="0" width="520" height="320" rx="6" class="fp-room fp-living"/>
      <text x="540" y="150" class="fp-room-label fp-label-large">餐厅 + 客厅</text>
      <text x="540" y="178" class="fp-room-area fp-area-large">~30㎡</text>

      <path d="M310 500 L310 470 L350 470 L350 500" class="fp-door"/>
      <text x="330" y="465" class="fp-door-label">入户门</text>
    </svg>
  </div>

  <div class="location-section">
    <h2 class="location-title">重要物品存放</h2>
    <div class="map-grid">
      {locations.map(loc => (
        <div class="map-card">
          <h3 class="map-item-name">{loc.item}</h3>
          <p class="map-location">{loc.location}</p>
        </div>
      ))}
    </div>
  </div>
</div>
